# ── Runtime mode ──────────────────────────────────────────────────────────────
# Set to "true" to run as a RunPod serverless handler instead of HTTP server.
RUNPOD_ENABLED=false

# Pre-load all model weights at startup instead of on the first request.
# When R2_ENABLED=true, this also triggers the R2 download before GPU loading.
PRELOAD_MODELS=false

# Flask / Gunicorn (ignored when RUNPOD_ENABLED=true)
PORT=5000

# ── Model ─────────────────────────────────────────────────────────────────────
# HuggingFace token — required only for gated models (e.g. FLUX.1-dev)
# HF_TOKEN=hf_...

# Model to load (default: black-forest-labs/FLUX.1-schnell)
# Switch to FLUX.1-dev for higher quality (requires HF_TOKEN)
# MODEL_ID=black-forest-labs/FLUX.1-schnell
# MODEL_ID=black-forest-labs/FLUX.1-dev

# HuggingFace cache directory
# HF_HOME=/cache/huggingface

# ControlNet adapter model (Apache 2.0 — no token needed)
# CONTROLNET_MODEL_ID=InstantX/FLUX.1-dev-Controlnet-Canny

# Set to "false" to skip downloading the ControlNet adapter on startup
# DOWNLOAD_CONTROLNET=true

# ── Cloudflare R2 model cache ─────────────────────────────────────────────────
# Enables the R2 strategy: download model from R2 on cold start instead of
# HuggingFace. No region lock, free egress, global availability.
#
# Setup:
#   1. Create a bucket on Cloudflare R2
#   2. Generate an R2 API token (Account → R2 → Manage R2 API Tokens)
#   3. Run: python scripts/upload_to_r2.py  (once, CPU pod is enough)
#   4. Set R2_ENABLED=true in your RunPod endpoint environment variables
#
# R2_ENABLED=false
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=flux-models
